# Dockerfile for running integration tests in Azure Container Instances
# This container runs within the VNet subnet to access resources via private endpoints and VNet rules

FROM mcr.microsoft.com/dotnet/sdk:10.0 AS build

WORKDIR /src

# Copy everything
COPY . .

# Restore all projects
RUN dotnet restore SqlBuildManager.Console.ExternalTest/SqlBuildManager.Console.ExternalTest.csproj
RUN dotnet restore SqlBuildManager.Console.PostgreSQL.ExternalTest/SqlBuildManager.Console.PostgreSQL.ExternalTest.csproj

# Build the test projects (this also builds dependencies)
RUN dotnet build SqlBuildManager.Console.ExternalTest/SqlBuildManager.Console.ExternalTest.csproj --configuration Release --no-restore -o /tests
RUN dotnet build SqlBuildManager.Console.PostgreSQL.ExternalTest/SqlBuildManager.Console.PostgreSQL.ExternalTest.csproj --configuration Release --no-restore -o /tests

# Copy TestConfig files to test output directory
RUN cp -r TestConfig /tests/TestConfig

# Create the final test runner image (using SDK since we need dotnet test)
FROM mcr.microsoft.com/dotnet/sdk:10.0 AS testrunner

# Install Azure CLI and kubectl
RUN apt-get update && \
    apt-get install -y curl gnupg lsb-release && \
    curl -sL https://aka.ms/InstallAzureCLIDeb | bash && \
    curl -LO "https://dl.k8s.io/release/$(curl -L -s https://dl.k8s.io/release/stable.txt)/bin/linux/amd64/kubectl" && \
    install -o root -g root -m 0755 kubectl /usr/local/bin/kubectl && \
    rm kubectl && \
    apt-get clean && \
    rm -rf /var/lib/apt/lists/*

WORKDIR /tests

# Copy built test assemblies and TestConfig
COPY --from=build /tests .

# Set environment variables for test execution
ENV DOTNET_ENVIRONMENT=Production
ENV AZURE_CLIENT_ID=""

# Default entry point runs all tests, but can be overridden with --filter
# Examples:
#   --filter "FullyQualifiedName~ContainerApp"
#   --filter "FullyQualifiedName~AciTests"
#   --filter "TestCategory=Integration"
ENTRYPOINT ["dotnet", "vstest", "SqlBuildManager.Console.ExternalTest.dll", "--logger:trx;LogFileName=TestResults.trx", "--logger:console;verbosity=detailed"]
